{
  "name": "dreamteam-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:types": "supabase gen types typescript --project-id rfsvmhcqeiyrxivbmpel --schema public > src/types/database.types.ts",
    "migrate:apply": "node scripts/apply-migration.mjs",
    "migrate:status": "node scripts/migration-status.mjs",
    "provision:all": "node scripts/provision.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.64.0",
    "@supabase/supabase-js": "^2.39.0",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.5.2",
    "dotenv": "^17.4.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.2",
    "vite": "^4.4.0",
    "vitest": "^4.1.10",
    "ws": "^8.21.0"
  }
}
