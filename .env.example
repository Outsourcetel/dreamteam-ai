# ── Supabase (required) ──────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase service role (server-side only — never expose to browser) ──
# Used for Edge Functions and admin scripts, not for the Vite frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AI providers (Phase 2 — not required in Sprint 1) ────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── App config ───────────────────────────────────────────────────
VITE_APP_ENV=development
# Set to 'true' to show demo login shortcuts (development only)
VITE_DEMO_MODE=false
