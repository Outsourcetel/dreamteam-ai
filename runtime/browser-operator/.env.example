# ── DreamTeam Browser Operator worker — configuration ──
# Copy to .env and fill in. The worker needs the service role (it goes through
# the mig-182/241/242 governed RPCs, never raw tables) and an Anthropic key.

# Supabase (prod ref rfsvmhcqeiyrxivbmpel) — service role, kept ONLY on this
# server, never shipped to the browser.
SUPABASE_URL=https://rfsvmhcqeiyrxivbmpel.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — the reasoning loop. DOM engine needs no beta header; vision
# fallback (future) needs anthropic-beta: computer-use-2025-11-24.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Steel (self-hosted). With docker-compose the Steel API is http://steel:3000.
# Steel gives each task an isolated Chrome; the worker connects over CDP.
STEEL_BASE_URL=http://localhost:3000
STEEL_API_KEY=

# Worker identity + cadence
RUNTIME_NAME=browser-operator-1
POLL_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=45000
